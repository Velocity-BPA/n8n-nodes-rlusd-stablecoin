{
  "name": "@velocity-bpa/n8n-nodes-rlusd-stablecoin",
  "version": "1.0.0",
  "description": "RLUSD Stablecoin node for n8n - Manages RLUSD token balance queries and account information across XRPL and Ethereum networks",
  "license": "bsl-catalog",
  "homepage": "https://github.com/velocity-bpa/n8n-nodes-rlusd-stablecoin",
  "author": {
    "name": "Velocity BPA",
    "email": "support@velocity-bpa.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/velocity-bpa/n8n-nodes-rlusd-stablecoin.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@9.1.4",
  "main": "index.js",
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes credentials package.json",
    "lintfix": "eslint nodes credentials package.json --fix",
    "prepublishOnly": "npm run build",
    "test": "jest"
  },
  "files": [
    "dist/**/*"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/RLUSDStablecoinApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/RLUSDStablecoin/RLUSDStablecoin.node.js"
    ]
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.15.2",
    "@typescript-eslint/parser": "^7.15.2",
    "eslint": "^8.56.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.1",
    "gulp": "^4.0.2",
    "n8n-workflow": "*",
    "prettier": "^3.3.2",
    "typescript": "~5.2.2"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "dependencies": {
    "axios": "^1.7.2"
  }
}